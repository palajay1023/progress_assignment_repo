# ── LLM Provider ─────────────────────────────────────────────────────────────
# Pick ONE provider block below, fill in the key, then set LLM_MODEL.

# OpenAI
LLM_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o


# OpenRouter  (access Claude, GPT-4, Llama, Gemini, etc. via one key)
LLM_API_KEY=sk-or-...
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-sonnet-4-5
LLM_MODEL=openai/gpt-4o
LLM_MODEL=deepseek/deepseek-chat

# Any other OpenAI-compatible endpoint (Ollama, Together, Groq, etc.)
LLM_API_KEY=...
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3

# ── Other services ────────────────────────────────────────────────────────────
TAVILY_API_KEY=your_tavily_api_key_here
DATABASE_URL=sqlite:///./market_intelligence.db
